<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/ivFloatingAssistant"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_floating_assistant"
        android:padding="12dp"
        android:src="@drawable/ic_shield"
        android:contentDescription="Assistant Icon"
        app:tint="@color/active_green" />

    <LinearLayout
        android:id="@+id/llFloatingMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_status_badge"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="invisible">

        <ImageView
            android:id="@+id/ivScan"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_floating_assistant"
            android:padding="10dp"
            android:src="@drawable/ic_scan"
            app:tint="@color/active_green" />

        <ImageView
            android:id="@+id/ivText"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_floating_assistant"
            android:padding="10dp"
            android:src="@drawable/ic_text"
            app:tint="@color/active_green" />

        <ImageView
            android:id="@+id/ivLink"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_floating_assistant"
            android:padding="10dp"
            android:src="@drawable/ic_link"
            app:tint="@color/active_green" />

        <ImageView
            android:id="@+id/ivOff"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_floating_assistant"
            android:padding="10dp"
            android:src="@drawable/ic_power"
            app:tint="#FF4B4B" />
    </LinearLayout>
</LinearLayout>